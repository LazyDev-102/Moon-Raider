  - {fileID: 21300004, guid: 9f259e1d84f1f9944af02abe4f687558, type: 3}
  - {fileID: 21300006, guid: 9f259e1d84f1f9944af02abe4f687558, type: 3}
  - {fileID: 21300008, guid: 9f259e1d84f1f9944af02abe4f687558, type: 3}
  - {fileID: 21300010, guid: 9f259e1d84f1f9944af02abe4f687558, type: 3}
  AnimationSpeed: 0.025
  Box: {fileID: 7770449892708518981}
  Bar: {fileID: 2903582611221125528}
  ChatName: {fileID: 6274848834926841924}
  ChatText: {fileID: 2187757982319264941}
  ThingsToSay:
  - Ava, you made it. Well done!
  - Use the { input } { inputType } to jump. Press again in-air to double jump.
  - Use the { input } { inputType } to shoot. Hold it for rapid fire.
  - Good luck!
  - Amazing! Your suit absorbs more damage now.
  - Incredible! You can now dash like that dead brute.
  - Just hold a direction and the { input } { inputType } to dash attack.
  - Your suit now holds more gem energy.
  - Your blaster now does more damage.
  - Hold the { input } { inputType } while running to clear that lava.
  - Yes! That's exactly the type of gem we need to save your mother. Find { total
    } of those.
  - You've done it! We have enough gems to save your mother.
  - Now you just have to find your way out of here. That took me three years. Good
    luck!
  SlideUpSound: {fileID: 8300000, guid: 37a04009dec562e479e119f957a7f8f6, type: 3}
  SlideDownSound: {fileID: 8300000, guid: 9564a0358c8647e4d91b10c491600918, type: 3}
  Jargon1Sound: {fileID: 8300000, guid: 752cb58be702190438f377102fdd3f5d, type: 3}
  Jargon2Sound: {fileID: 8300000, guid: e523d94d7a6a289488e929a22faba0df, type: 3}
